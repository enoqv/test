{
  "name": "Claude Code Sandbox (Squid Proxy)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "dever",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "mhutchie.git-graph",
        "golang.go"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dever/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true",
    "HTTP_PROXY": "http://squid:3128",
    "HTTPS_PROXY": "http://squid:3128",
    "http_proxy": "http://squid:3128",
    "https_proxy": "http://squid:3128",
    "NO_PROXY": "localhost,127.0.0.1,::1,squid,postgres,redis",
    "no_proxy": "localhost,127.0.0.1,::1,squid,postgres,redis"
  },
  "postCreateCommand": "bash /workspace/.devcontainer/claude-setup.sh",
  "postStartCommand": "sudo /usr/local/bin/init-proxy.sh",
  "waitFor": "postStartCommand",
  "overrideCommand": true,
  // Auto-forward the app's HTTP port to the host so `go run ./cmd/server`
  // (which binds :8080 by default per internal/config) is reachable from a
  // host browser at http://localhost:8080. VS Code shows a notification
  // when the port goes live; the host side picks an available port if 8080
  // is already taken on the host.
  "forwardPorts": [8080],
  // Skip the auto-generated `FROM $BASE_IMAGE` overlay that devcontainer
  // CLI uses to align the container user's UID/GID with the host. The
  // `dever` user in our Dockerfile already has a reasonable UID, and the
  // overlay Dockerfile is what produces the harmless
  // `InvalidDefaultArgInFrom: Default value for ARG $BASE_IMAGE ...`
  // warning from BuildKit during `devcontainer up`.
  "updateRemoteUserUID": false
}
